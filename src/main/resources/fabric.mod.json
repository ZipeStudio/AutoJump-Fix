{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${mod_version}",
    "name": "${mod_name}",
    "description": "${mod_description}",
    "authors": [
        "${mod_authors}"
    ],
    "contact": {
        "homepage": "https://modrinth.com/mod/${mod_slug}",
        "issues": "https://github.com/${github_author}/${mod_slug}"
    },
    "license": "${mod_license}",
    "icon": "icon/icon.png",
    "environment": "${fabric_trick_side}",
    "entrypoints": {
        "main": [
            "me.zipestudio.autojumpfix.entrypoint.CommonEntrypoint"
        ],
        "client": [
            "me.zipestudio.autojumpfix.entrypoint.ClientEntrypoint"
        ]
    },
    "depends": {
        "fabricloader": ">=${fabric_loader}",
        "minecraft": ">=${minecraft}",
        "java": ">=${java}",
        "${fabric_api_id}": "*"
    },
	"accessWidener": "${fabric_trick_accesswidener_id}",
    "mixins": [
        "${fabric_trick_mixin_configs}"
    ]
}